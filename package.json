{
  "name": "code-content",
  "version": "2.0.0",
  "description": "Ollama-powered book generator with web dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "node server.js",
    "generate": "node worker.js",
    "generate:book": "node worker.js",
    "generate:book:all": "node worker.js --all",
    "generate:book:bg": "node worker.js --all --detach",
    "generate:book:ps": "pgrep -a -f 'worker.js' || echo 'No worker process running'",
    "generate:book:kill": "pkill -f 'worker.js' && echo 'Worker stopped' || echo 'No worker process found'",
    "export:pdf": "node scripts/export-pdf.js",
    "export:pdf:css": "node scripts/export-pdf.js book-css",
    "export:pdf:html": "node scripts/export-pdf.js book-html",
    "export:pdf:js": "node scripts/export-pdf.js book-js",
    "export:pdf:python": "node scripts/export-pdf.js book-python",
    "export:pdf:linux": "node scripts/export-pdf.js book-linux",
    "export:all": "for book in books/*/; do node scripts/export-pdf.js \"$(basename $book)\"; done"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "express": "^4.22.1",
    "ollama": "^0.5.0"
  }
}
