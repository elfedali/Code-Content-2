# ── Ollama ──────────────────────────────────────────────────────────────────
# Ollama is running locally on this machine (ThinkCenter)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# ── Generation ───────────────────────────────────────────────────────────────
# Delay in milliseconds between section generation requests (avoids overloading)
GENERATION_DELAY_MS=3000

# ── Dashboard server ─────────────────────────────────────────────────────────
# Port to expose the web dashboard on (access via http://<thinkcenter-ip>:4040)
PORT=4040

# ── WordPress (optional, not used in current workflow) ───────────────────────
# WP_URL=https://your-site.com
# WP_USERNAME=username
# WP_PASSWORD=password
